EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=https://api.ontiver.com
EXPO_PUBLIC_WEBSITE_URL=https://ontiver.com
EXPO_PUBLIC_SUPPORT_EMAIL=support@ontiver.com
EXPO_PUBLIC_SMILEID_ENVIRONMENT=sandbox
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# EAS build variables. Configure these with `eas env:create`; do not commit the referenced files.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_REVERSED_CLIENT_ID=
GOOGLE_SERVICES_JSON=
GOOGLE_SERVICE_INFO_PLIST=
SENTRY_AUTH_TOKEN=

# EAS Submit credentials. Use secret file variables for key paths.
EXPO_ASC_API_KEY_PATH=
EXPO_ASC_KEY_ID=
EXPO_ASC_ISSUER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
