{
  "name": "ontiver-apk",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@12.0.1",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nitro-google-signin",
          "@smile_identity/react-native-expo"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "check:fixtures": "node scripts/check-production-fixtures.mjs",
    "check": "npm run typecheck && npm run check:fixtures"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo-google-fonts/roboto-mono": "^0.4.2",
    "@expo/vector-icons": "15.1.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@sentry/react-native": "~7.11.0",
    "@smile_identity/react-native-expo": "11.2.10",
    "@tanstack/react-query": "5.101.2",
    "expo": "~56.0.16",
    "expo-apple-authentication": "~56.0.4",
    "expo-blur": "~56.0.4",
    "expo-build-properties": "~56.0.0",
    "expo-camera": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.21",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.0",
    "expo-device": "~56.0.0",
    "expo-font": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-local-authentication": "~56.0.4",
    "expo-notifications": "~56.0.21",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-updates": "~56.0.22",
    "expo-web-browser": "~56.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-nitro-google-signin": "^1.0.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "zod": "4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "brace-expansion": "5.0.8",
    "js-yaml": "4.3.0",
    "shell-quote": "1.9.0",
    "svgo": "3.3.4"
  }
